{
  "name": "pixel-agent-buddy",
  "version": "0.2.0-beta.2",
  "description": "Privacy-first pixel desktop companion for Claude Code and Codex",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron ./electron/main.cjs",
    "dev": "electron ./electron/main.cjs",
    "build": "node scripts/verify.cjs",
    "verify:packaged-hook": "node scripts/verify-packaged-hook.cjs",
    "generate:assets": "electron scripts/generate-pixel-pets.cjs",
    "preview:assets": "electron scripts/capture-pet-previews.cjs",
    "preview:hero": "electron scripts/capture-hero.cjs",
    "test": "node --test test/*.test.cjs",
    "doctor": "node scripts/doctor.cjs",
    "install:hooks": "node scripts/install-hooks.cjs",
    "install:claude": "node scripts/install-hooks.cjs --claude",
    "install:codex": "node scripts/install-hooks.cjs --codex",
    "uninstall:hooks": "node scripts/uninstall-hooks.cjs",
    "build:win": "node scripts/build-windows.cjs nsis",
    "build:portable": "node scripts/build-windows.cjs portable"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "claude-code",
    "codex",
    "coding-agent",
    "privacy-first",
    "pixel-art"
  ],
  "author": "44-99",
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "app.pixelagentbuddy.desktop",
    "productName": "Pixel Agent Buddy",
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "src/**/*",
      "hooks/**/*",
      "scripts/hook-config.cjs",
      "scripts/hook-installer.cjs",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "Pixel-Agent-Buddy-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Pixel-Agent-Buddy-${version}-${arch}-portable.exe"
    }
  }
}
